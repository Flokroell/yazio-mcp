  "license": "MIT",
  "homepage": "https://github.com/Flokroell/yazio-mcp#readme",
  "bugs": {
    "url": "https://github.com/Flokroell/yazio-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flokroell/yazio-mcp.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
