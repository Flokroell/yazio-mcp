{
  "name": "yazio-mcp",
  "version": "1.0.0",
  "description": "Connect your Yazio calorie tracker to Claude and other AI agents via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "yazio-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
